{
  "name": "@afenda/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --target es2022 --clean",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node -e \"console.log('worker: test noop')\"",
    "lint": "node -e \"console.log('worker: lint noop')\""
  },
  "dependencies": {
    "@afenda/contracts": "workspace:*",
    "@afenda/core": "workspace:*",
    "@afenda/db": "workspace:*",
    "dotenv": "catalog:",
    "graphile-worker": "catalog:"
  },
  "devDependencies": {
    "@afenda/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
