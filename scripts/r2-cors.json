{
  "rules": [
    {
      "allowed": {
        "origins": ["http://localhost:3000", "https://nexuscanon.com", "https://*.nexuscanon.com"],
        "methods": ["GET", "PUT", "DELETE"],
        "headers": ["Content-Type", "Content-MD5", "x-amz-content-sha256"]
      },
      "exposeHeaders": ["ETag"],
      "maxAgeSeconds": 3600
    }
  ]
}
