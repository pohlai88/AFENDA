{
  "name": "afenda-nexus",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "check:boundaries": "node tools/gates/boundaries.mjs",
    "check:catalog": "node tools/gates/catalog.mjs",
    "check:all": "node tools/run-gates.mjs",
    "db:migrate": "pnpm -C packages/db db:migrate",
    "db:generate": "pnpm -C packages/db db:generate",
    "db:seed": "pnpm -C packages/db db:seed",
    "db:studio": "pnpm -C packages/db db:studio"
  },
  "devDependencies": {
    "@afenda/tsconfig": "workspace:*",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "yaml": "catalog:"
  }
}
