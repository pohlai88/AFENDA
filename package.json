{
  "name": "afenda-nexus",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:coverage": "turbo run test -- --coverage",
    "lint": "turbo run lint",
    "check:boundaries": "node tools/gates/boundaries.mjs",
    "check:catalog": "node tools/gates/catalog.mjs",
    "check:contract-db-sync": "node tools/gates/contract-db-sync.mjs",
    "check:server-clock": "node tools/gates/server-clock.mjs",
    "check:no-unsafe-money-formatting": "node tools/gates/no-unsafe-money-formatting.mjs",
    "check:owners-lint": "node tools/gates/owners-lint.mjs",
    "check:token-compliance": "node tools/gates/token-compliance.mjs",
    "check:ui-meta": "node tools/gates/ui-meta.mjs",
    "check:domain-completeness": "node tools/gates/domain-completeness.mjs",
    "check:route-registry-sync": "node tools/gates/route-registry-sync.mjs",
    "check:org-isolation": "node tools/gates/org-isolation.mjs",
    "check:audit-enforcement": "node tools/gates/audit-enforcement.mjs",
    "check:finance-invariants": "node tools/gates/finance-invariants.mjs",
    "check:page-states": "node tools/gates/page-states.mjs",
    "check:ui-shell": "node tools/gates/ui-shell.mjs",
    "check:all": "node tools/run-gates.mjs",
    "scaffold": "node tools/scaffold.mjs",
    "db:migrate": "pnpm -C packages/db db:migrate",
    "db:generate": "pnpm -C packages/db db:generate",
    "db:seed": "pnpm -C packages/db db:seed",
    "db:studio": "pnpm -C packages/db db:studio",
    "sync:env": "node scripts/sync-env-config-to-env.mjs",
    "neon:auth-validate": "node scripts/validate-neon-auth-env.mjs",
    "neon:auth-config": "node scripts/neon-auth-config.mjs",
    "neon:auth-sync-fix": "pnpm -C packages/db node scripts/run-fix-neon-auth-sync.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e": "pnpm -C apps/web e2e",
    "e2e:auth": "pnpm -C apps/web exec playwright test e2e/smoke.spec.ts --project=chromium --workers=1",
    "e2e:auth:reuse": "set PLAYWRIGHT_BASE_URL=http://localhost:3000&& pnpm -C apps/web exec playwright test e2e/smoke.spec.ts --project=chromium --workers=1",
    "dev:e2e": "turbo run dev --filter=@afenda/web --filter=@afenda/api"
  },
  "devDependencies": {
    "@afenda/tsconfig": "workspace:*",
    "@eslint/js": "catalog:",
    "@playwright/test": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-drizzle": "catalog:",
    "eslint-plugin-jsx-a11y": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "prettier": "catalog:",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:",
    "yaml": "catalog:"
  },
  "dependencies": {
    "@neondatabase/auth": "catalog:",
    "@neondatabase/neon-js": "catalog:",
    "better-auth": "catalog:"
  }
}
