{
  "name": "@afenda/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "node -e \"console.log('core: dev noop')\"",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ap:calc": "vitest run src/erp/finance/ap/__vitest_test__/three-way-match.test.ts src/erp/finance/ap/__vitest_test__/detect-duplicates.test.ts src/erp/finance/ap/__vitest_test__/payment-file-iso20022.test.ts src/erp/finance/ap/__vitest_test__/payment-file-nacha.test.ts",
    "test:ap:services": "vitest run src/erp/finance/ap/__vitest_test__/aging.service.test.ts src/erp/finance/ap/__vitest_test__/hold.service.test.ts src/erp/finance/ap/__vitest_test__/invoice.service.test.ts src/erp/finance/ap/__vitest_test__/match-tolerance.service.test.ts src/erp/finance/ap/__vitest_test__/payment-run.service.test.ts src/erp/finance/ap/__vitest_test__/payment-run-export.service.test.ts src/erp/finance/ap/__vitest_test__/prepayment.service.test.ts src/erp/finance/ap/__vitest_test__/validate-invoice.test.ts src/erp/finance/ap/__vitest_test__/wht-certificate.service.test.ts",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@afenda/contracts": "workspace:*",
    "@afenda/db": "workspace:*",
    "@opentelemetry/api": "^1.9.0",
    "drizzle-orm": "catalog:",
    "otplib": "catalog:",
    "pino": "catalog:",
    "pino-pretty": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@afenda/tsconfig": "workspace:*",
    "@opentelemetry/auto-instrumentations-node": "^0.70.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.212.0",
    "@opentelemetry/sdk-node": "^0.212.0",
    "@opentelemetry/sdk-trace-base": "^2.5.1",
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
