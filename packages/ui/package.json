    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "input-otp": "catalog:",
    "lucide-react": "catalog:",
    "next-themes": "catalog:",
    "radix-ui": "catalog:",
    "react": "catalog:",
    "react-day-picker": "^9.14.0",
    "react-resizable-panels": "catalog:",
    "recharts": "catalog:",
    "react-hook-form": "catalog:",
    "sonner": "^2.0.7",
    "tailwind-merge": "catalog:",
    "zod": "catalog:",
    "zustand": "^5.0.11"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19.2.4",
    "tailwindcss": ">=4.0.0"
  },
  "devDependencies": {
    "@afenda/tsconfig": "workspace:*",
