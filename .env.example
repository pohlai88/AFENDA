# ─── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development

# ─── DB (API — pooled in prod; direct locally) ──────────────────────────────
DATABASE_URL=postgres://afenda:afenda@localhost:5433/afenda_dev

# ─── DB (Worker — always direct connection) ──────────────────────────────────
WORKER_DATABASE_URL=postgres://afenda:afenda@localhost:5433/afenda_dev

# ─── Auth (NextAuth) ─────────────────────────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=IfRkM3AJsYVAUlwCXgy/7VyxGsAn1hL0w1clWryJKLw=

# ─── OpenTelemetry ───────────────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=afenda-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ─── S3 / Object Storage (local MinIO defaults) ──────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=afenda-dev
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio12345

# ─── API ─────────────────────────────────────────────────────────────────────
API_PORT=3001
ALLOWED_ORIGINS=http://localhost:3000

# ─── Web (Next.js) ───────────────────────────────────────────────────────────
# API base URL for server-side calls (NextAuth authorize, api-client, etc.)
NEXT_PUBLIC_API_URL=http://localhost:3001

# ─── Demo credentials (run `pnpm db:seed` first) ─────────────────────────────
# Email:    admin@demo.afenda
# Password: demo123

# ─── E2E tests (optional overrides for Playwright auth tests) ─────────────────
