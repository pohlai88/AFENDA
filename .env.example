# ============================================================================
# AFENDA — Environment Configuration (Example)
# Copy this file to .env and fill in your actual values
# ============================================================================

# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
PORT=3000
BASE_URL=http://localhost:3000
SESSION_SECRET=your-session-secret-change-in-production

# ── Dev Credentials ──────────────────────────────────────────────────────────
ENABLE_DEV_CREDENTIALS=true
DEV_AUTH_USERNAME=admin
DEV_AUTH_PASSWORD=admin

# ── Database (Local PostgreSQL) ──────────────────────────────────────────────
# API — pooled connection in prod; direct locally
DATABASE_URL=postgres://afenda:afenda@localhost:5433/afenda_dev
# Worker — always direct connection
WORKER_DATABASE_URL=postgres://afenda:afenda@localhost:5433/afenda_dev

# ── Neon Database (Production) ───────────────────────────────────────────────
# Uncomment and configure for production Neon deployment
# Runtime: pooled connection via PgBouncer (serverless-safe)
# Add sslnegotiation=direct for faster SSL (Postgres 17+ client)
# DATABASE_URL=postgresql://user:password@endpoint-pooler.region.aws.neon.tech/db?sslmode=require&channel_binding=require&sslnegotiation=direct
# Migrations: direct TCP (required for DDL, advisory locks) — pnpm db:migrate uses this when set
# DATABASE_URL_MIGRATIONS=postgresql://user:password@endpoint.region.aws.neon.tech/db?sslmode=require&sslnegotiation=direct
# Worker: direct TCP (no pooler) — Graphile Worker LISTEN/NOTIFY requires direct connection
# WORKER_DATABASE_URL=postgresql://user:password@endpoint.region.aws.neon.tech/db?sslmode=require&sslnegotiation=direct
# NEON_PROJECT_ID=your-project-id
# Pool tuning (optional): DB_POOL_MAX=5 for Neon serverless, DB_IDLE_TIMEOUT_MS=10000 for scale-to-zero
# NEON_BRANCH_ID=your-branch-id
# NEON_API_KEY=your-neon-api-key
# NEON_PASSWORDLESS_AUTH=-h pg.neon.tech

# ── Neon Auth (Managed Authentication) ──────────────────────────────────────────────────────────
# Neon Auth provides identity management (user, session, OAuth) built on Better Auth 1.4.18
# OAuth (Google/GitHub): configure providers in Neon Console → Auth; set callback URLs in Google/GitHub
# to your Neon Auth host, e.g. https://<neon-auth-host>/api/auth/callback/github — see docs/neon-oauth-configuration-plan.md
# Generate cookie secret: openssl rand -base64 32
# Base URL — server-side endpoint for SDK initialization and route proxying
NEON_AUTH_BASE_URL=https://lucky-silence-39754997.neonauth.ap-southeast-1.aws.neon.tech/neondb/auth
# Cookie secret — encrypts session cookies; must be 32+ chars
NEON_AUTH_COOKIE_SECRET=your-32-byte-base64-secret-from-console
# Optional: session cookie TTL in seconds (default 300). Set if sessions drop or refresh fails.
# NEON_AUTH_SESSION_TTL=300
# Optional: cookie domain for cross-subdomain sessions (e.g. .example.com). Set in production if auth redirects fail.
# NEON_AUTH_COOKIE_DOMAIN=
# Public URL — client-side endpoint for browser auth API calls (same as NEON_AUTH_BASE_URL)
# Used by @neondatabase/neon-js (createAuthClient, createClient) in apps/web/src/lib/neon-js-client.ts
NEXT_PUBLIC_NEON_AUTH_URL=https://lucky-silence-39754997.neonauth.ap-southeast-1.aws.neon.tech/neondb/auth
# JWKS endpoint — for API bearer token verification (auto-discovered from base URL)
NEON_AUTH_JWKS_URL=https://lucky-silence-39754997.neonauth.ap-southeast-1.aws.neon.tech/neondb/auth/.well-known/jwks.json

# ── Neon Data API ────────────────────────────────────────────────────────────
# Optional. When set, full Neon JS client (auth + Data API) is available in browser.
# Used by createClient() in apps/web/src/lib/neon-js-client.ts for client.from().select() etc.
# NEON_DATA_API_URL=https://endpoint.apirest.region.aws.neon.tech/db/rest/v1
# Client-side (Next.js): must be NEXT_PUBLIC_ for browser use
# NEXT_PUBLIC_NEON_DATA_API_URL=https://endpoint.apirest.region.aws.neon.tech/db/rest/v1

# ── App URL (for links and redirects) ────────────────────────────────────────
AUTH_URL=http://localhost:3000

# ── Auth Challenges (MFA, invite, reset) ─────────────────────────────────────
# HMAC secret for challenge token hashing; use: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_CHALLENGE_SECRET=your-auth-challenge-secret-generate-with-openssl-rand-hex-32

# ── Auth Evidence (export signing) ───────────────────────────────────────────
# HMAC secret for evidence export signatures
# AUTH_EVIDENCE_SIGNING_SECRET=your-evidence-signing-secret-generate-with-openssl-rand-hex-32

# MFA testing: demo user (admin@demo.afenda / demo123) has TOTP enrolled.
# Add secret JBSWY3DPEHPK3PXP to Google Authenticator to test MFA flow.

# ── Auth Backend (optional) ───────────────────────────────────────────────────
# When set, web app uses HTTP auth backend instead of API. For local/staging.
# AUTH_BACKEND_URL=http://localhost:3002
# AUTH_BACKEND_API_KEY=your-api-key
# MOCK_AUTH=1  # Use mock auth service (never succeeds; for UI dev)

# ── Auth Email (API) ────────────────────────────────────────────────────────
# Webhook URL for auth emails (reset, invites). When unset, API logs to stdout.
# AUTH_EMAIL_WEBHOOK_URL=https://hooks.zapier.com/your-webhook
# Password reset delivery: "link" (default) or "code"
# AUTH_PASSWORD_RESET_DELIVERY=link

# ── OAuth Providers (Neon Auth managed) ─────────────────────────────────────
# Configure GitHub/Google OAuth provider credentials in Neon Console.
# No AUTH_GITHUB_* / AUTH_GOOGLE_* env vars are required in this app.

# ── OpenTelemetry ────────────────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=afenda-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# For Grafana Cloud OTEL
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-region.grafana.net/otlp
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic%20your-base64-token
# OTEL_TOKEN=your-grafana-token

# ── Error Tracking ───────────────────────────────────────────────────────────
# GlitchTip / Sentry
# SENTRY_DSN=https://key@app.glitchtip.com/project-id

# ── Storage ──────────────────────────────────────────────────────────────────
# Provider: r2 | s3
STORAGE_PROVIDER=r2

# Cloudflare R2 (Default)
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=afenda-dev
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
# R2_PUBLIC_BASE_URL=https://pub-xxx.r2.dev (optional, for public buckets)
# R2_BACKUP_BUCKET=your-backup-bucket (optional)

# S3-compatible vars used by both providers at runtime fallback layer
S3_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=afenda-dev
S3_ACCESS_KEY_ID=your-r2-access-key
S3_SECRET_ACCESS_KEY=your-r2-secret-key
# S3_FORCE_PATH_STYLE=false

# Local MinIO profile example
# STORAGE_PROVIDER=s3
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=auto
# S3_BUCKET=afenda-dev
# S3_ACCESS_KEY_ID=minio
# S3_SECRET_ACCESS_KEY=minio12345
# S3_FORCE_PATH_STYLE=true

# ── Email (Resend) ───────────────────────────────────────────────────────────
# RESEND_API_KEY=re_your-resend-api-key
# DEFAULT_FROM_EMAIL=no-reply@yourdomain.com
# DEFAULT_FROM_NAME=Your Company Name

# ── API ──────────────────────────────────────────────────────────────────────
API_PORT=3001
ALLOWED_ORIGINS=http://localhost:3000

# ── Next.js Public Variables ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Web app base URL for auth links (password reset, invite). Falls back to NEXT_PUBLIC_APP_URL.
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# ── Figma ────────────────────────────────────────────────────────────────────
# FIGMA_PERSONAL_ACCESS_TOKEN=figd_your-personal-access-token
# FIGMA_TOKEN=figd_your-team-token
# FIGMA_FILE_KEY=your-figma-file-key

# ── Third-Party API Keys ─────────────────────────────────────────────────────
# GITHUB_TOKEN=github_pat_your-github-personal-access-token
# OPENAI_API_KEY=sk-your-openai-api-key
# NPM_ACCESS_TOKEN=npm_your-npm-access-token
# BASEHUB_TOKEN=bshb_pk_your-basehub-token
# ARCJET_KEY=ajkey_your-arcjet-key
# POSTHOG_KEY=phc_your-posthog-key

# ── Stripe ───────────────────────────────────────────────────────────────────
# STRIPE_CLI_KEY=mk_your-stripe-cli-key
# STRIPE_SECRET_KEY=mk_your-stripe-secret-key
# STRIPE_PUBLISHABLE_KEY=mk_your-stripe-publishable-key

# ── BetterStack ──────────────────────────────────────────────────────────────
# BETTERSTACK_GLOBAL_API_KEY=your-betterstack-global-api-key
# BETTERSTACK_UPTIME_API_TOKEN=your-betterstack-uptime-token

# ── Redis (Upstash / RedisLabs) ─────────────────────────────────────────────
# Required for rate limiting, session storage when enabled
# REDIS_URL=redis://default:password@host:port
# Or: REDIS_HOST, REDIS_PORT, REDIS_PASSWORD

# ── Demo Credentials ─────────────────────────────────────────────────────────
# Run `pnpm db:seed` first
# Email:    admin@demo.afenda
# Password: demo123

# ── E2E Tests ────────────────────────────────────────────────────────────────
# Optional overrides for Playwright auth tests
# E2E_TEST_USER_EMAIL=admin@demo.afenda
# E2E_TEST_USER_PASSWORD=demo123
